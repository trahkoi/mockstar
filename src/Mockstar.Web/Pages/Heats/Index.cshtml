@page
@model Mockstar.Web.Pages.Heats.IndexModel
@{
    ViewData["Title"] = "Heats";
}

<section class="placeholder-panel">
    <div class="eyebrow">Heat selection</div>
    <h1>Imported heats</h1>
    <p class="page-copy">
        Imported events are loaded from the database. Select a heat to view its entries and open scoring.
    </p>
    <div class="placeholder-layout import-layout">
        <article class="placeholder-card">
            <h2>Event list</h2>
            <div id="heats-list" class="stack">
                @if (!Model.ViewModel.HasEvents)
                {
                    <p class="placeholder-copy">No events imported yet. <a asp-page="/Import/Index">Import a roster</a> to get started.</p>
                }
                else
                {
                    @foreach (var eventSection in Model.ViewModel.EventSections)
                    {
                        <div class="stack">
                            <h3>@eventSection.EventName</h3>
                            @foreach (var heat in eventSection.Heats)
                            {
                                <button
                                    type="button"
                                    class="button button-secondary heat-picker"
                                    data-heat-id="@heat.Id"
                                    hx-get="@Url.Page("/Heats/Index", "Detail", new { heatId = heat.Id })"
                                    hx-target="#heat-detail"
                                    hx-swap="innerHTML">
                                    @heat.Name
                                </button>
                            }
                        </div>
                    }
                }
            </div>
        </article>
        <article class="placeholder-card">
            <h2>Heat detail</h2>
            <div id="heat-detail">
                <p class="placeholder-copy">Choose a heat to inspect its entries and open scoring.</p>
            </div>
        </article>
        <article class="placeholder-card">
            <h2>Workflow</h2>
            <ul class="meta-list">
                <li>Import roster data</li>
                <li>Select the active heat here</li>
                <li>Score it on the dedicated scoring page</li>
            </ul>
        </article>
    </div>
</section>
