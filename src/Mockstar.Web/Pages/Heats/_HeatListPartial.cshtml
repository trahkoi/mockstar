@model Mockstar.Web.Pages.Heats.HeatListViewModel

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <p class="placeholder-copy">@Model.Message</p>
}
else
{
    @foreach (var eventSection in Model.EventSections)
    {
        <section class="stack">
            <h3>@eventSection.EventName</h3>
            @foreach (var heat in eventSection.Heats)
            {
                var isSelected = string.Equals(Model.SelectedHeatId, heat.Id, StringComparison.Ordinal);
                <button
                    type="button"
                    class="button @(isSelected ? "button-primary" : "button-secondary") heat-picker"
                    data-heat-id="@heat.Id">
                    @heat.Name
                </button>
            }
        </section>
    }
}
