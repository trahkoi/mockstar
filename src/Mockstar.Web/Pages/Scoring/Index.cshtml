@page
@model Mockstar.Web.Pages.Scoring.IndexModel
@{
    ViewData["Title"] = "Scoring";
}

<form id="scoring-antiforgery" class="is-hidden">
    @Html.AntiForgeryToken()
</form>

<section class="placeholder-panel">
    <div class="eyebrow">Live scoring</div>
    <h1>Heat scoring</h1>
    <p class="page-copy">
        Razor owns the scoring markup. Client-side state keeps judging immediate, and HTMX reloads the server-rendered
        shell when the active role or structural controls change.
    </p>
    <div id="scoring-shell" class="stack">
        <div class="placeholder-card">
            <p class="placeholder-copy">No active heat selected yet.</p>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/scoring.js" asp-append-version="true"></script>
}
