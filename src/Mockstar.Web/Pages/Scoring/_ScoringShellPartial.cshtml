@model Mockstar.Web.Pages.Scoring.ScoringShellViewModel

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="placeholder-card">
        <p class="placeholder-copy">@Model.Message</p>
    </div>
}
else
{
    <div data-active-role="@Model.ActiveRole">
        <div class="placeholder-card">
            <div class="eyebrow">@Model.HeatType</div>
            <h2>@Model.HeatName</h2>
            <p class="placeholder-copy">@Model.RoleSummary</p>
        </div>

        @if (Model.ShowRoleSwitcher)
        {
            <div class="placeholder-chip-row">
                @foreach (var role in Model.Roles)
                {
                    <button
                        type="button"
                        class="placeholder-chip @(role.IsActive ? "active-chip" : string.Empty)"
                        data-role="@role.Id">
                        @role.Label
                    </button>
                }
            </div>
        }

        @if (Model.ShowPairingPanel)
        {
            <article class="placeholder-card">
                <h2>Pair finals</h2>
                <div class="placeholder-layout pairing-grid">
                    <label class="field">
                        <span>Leader bib</span>
                        <select data-pair-leader>
                            @foreach (var option in Model.LeaderOptions)
                            {
                                <option value="@option.Bib">@option.Display</option>
                            }
                        </select>
                    </label>
                    <label class="field">
                        <span>Follower bib</span>
                        <select data-pair-follower>
                            @foreach (var option in Model.FollowerOptions)
                            {
                                <option value="@option.Bib">@option.Display</option>
                            }
                        </select>
                    </label>
                    <button
                        type="button"
                        class="button button-secondary"
                        data-pair-submit
                        data-heat-id="@Model.PairingHeatId">
                        Link pair
                    </button>
                </div>
            </article>
        }

        <div class="scoreboard">
            @foreach (var row in Model.Rows)
            {
                <article class="score-row @(row.IsTied ? "is-tied" : string.Empty)" data-entry-id="@row.EntryId">
                    <div>
                        <strong>@row.Display</strong>
                        <div class="placeholder-copy">Rank <span class="rank-value">@row.Rank</span></div>
                    </div>
                    <label class="score-input">
                        <input
                            class="score-slider"
                            type="range"
                            min="0"
                            max="1000"
                            value="@row.Score"
                            data-entry-id="@row.EntryId"
                            @(row.IsDisabled ? "disabled" : null)>
                        <span class="score-value">@row.Score</span>
                    </label>
                </article>
            }
        </div>

        <button
            type="button"
            class="button button-primary"
            data-finalize
            @(Model.FinalizeDisabled ? "disabled" : null)>
            Finalize score sheet
        </button>
    </div>
}
