@page
@model Mockstar.Pages.Import.IndexModel
@{
    ViewData["Title"] = "Import";
}

<section class="placeholder-panel">
    <div class="eyebrow">Roster import</div>
    <h1>Roster import</h1>
    <p class="page-copy">
        Switch between web scraping and image OCR, then review parsed heats before they become active in the judging flow.
    </p>

    <div class="tab-strip">
        <button
            type="button"
            class="button button-primary tab-button"
            _="on click
                    remove .button-secondary from .tab-button in me.parentElement
                    add .button-secondary to <button.tab-button:not(me)/> in me.parentElement
                    remove .is-hidden from #image-panel
                    add .is-hidden to #web-panel">
            Image OCR
        </button>
        <button
            type="button"
            class="button button-secondary tab-button"
            _="on click
                    remove .button-secondary from .tab-button in me.parentElement
                    add .button-secondary to <button.tab-button:not(me)/> in me.parentElement
                    remove .is-hidden from #web-panel
                    add .is-hidden to #image-panel">
            Web import
        </button>
    </div>

    <div class="placeholder-layout import-layout">
        <article id="image-panel" class="placeholder-card">
            <h2>Image OCR</h2>
            <form id="ocr-form" class="stack" method="post" asp-page-handler="Text">
                @Html.AntiForgeryToken()
                <label class="field">
                    <span>Roster photo</span>
                    <input id="ocr-file" type="file" accept="image/*" />
                </label>
                <textarea id="ocr-text" name="extractedText" hidden></textarea>
                <button id="ocr-submit" type="button" class="button button-primary">Run OCR and Review</button>
                <p id="ocr-status" class="placeholder-copy">No image processed yet.</p>
            </form>
        </article>

        <article id="web-panel" class="placeholder-card is-hidden">
            <h2>Web import</h2>
            <form
                class="stack"
                method="post"
                asp-page-handler="Web"
                hx-post="@Url.Page("/Import/Index", new { handler = "Web" })"
                hx-target="#import-result"
                hx-swap="innerHTML">
                @Html.AntiForgeryToken()
                <label class="field">
                    <span>Roster URL</span>
                    <input type="url" name="url" placeholder="https://example.com/heat-roster" required />
                </label>
                <button type="submit" class="button button-primary">Scrape and Review</button>
            </form>
        </article>

        <article class="placeholder-card">
            <h2>Review target</h2>
            <p class="placeholder-copy">Parsed heats and ambiguous role prompts render below as an HTML fragment returned by the server.</p>
        </article>
    </div>
</section>

<section id="import-result" class="placeholder-panel">
    <div class="eyebrow">Review</div>
    <h2>Awaiting import</h2>
    <p class="placeholder-copy">Import a roster image or URL to inspect the parsed heat structure here.</p>
</section>

@section Scripts {
    <script src="~/js/import.js" asp-append-version="true"></script>
}
